# Token del bot de Telegram (obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN=

# Tu chat ID personal de Telegram (para recibir los recordatorios)
# Podés obtenerlo hablándole a @userinfobot
TELEGRAM_CHAT_ID=

# URL de tu proyecto en Supabase (Settings > API > Project URL)
SUPABASE_URL=

# Clave anónima de Supabase (Settings > API > anon public)
SUPABASE_ANON_KEY=

# API Key de OpenAI para transcripción de voz (Whisper)
# Obtenela en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# API Key de Anthropic para parseo de lenguaje natural con Claude
# Obtenela en: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Zona horaria
TIMEZONE=America/Argentina/Buenos_Aires
