# Token del bot de Telegram (obtenido desde @BotFather)
TELEGRAM_BOT_TOKEN=

# Tu chat ID personal de Telegram (para recibir los recordatorios)
# Podés obtenerlo hablándole a @userinfobot
TELEGRAM_CHAT_ID=

# URL de tu proyecto en Supabase (Settings > API > Project URL)
SUPABASE_URL=

# Clave anónima de Supabase (Settings > API > anon public)
SUPABASE_ANON_KEY=

# Zona horaria
TIMEZONE=America/Argentina/Buenos_Aires
